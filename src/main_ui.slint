import { Button, VerticalBox, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Data Processor";
    background: #121212; // Material Dark
    preferred-width: 360px;
    preferred-height: 640px;
    default-font-family: "sans-serif"; // Pakai font Android

    in-out property <string> input-data: "";
    in-out property <string> result-data: "Menunggu input...";

    callback process-data(string);

    VerticalBox {
        padding: 30px;
        spacing: 20px;
        alignment: start;

        Text {
            text: "Odfiz Processor";
            color: #ffffff;
            font-size: 24px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        Text {
            text: "Masukkan data untuk diproses di Rust:";
            color: #aaaaaa;
            font-size: 24px;
        }

        LineEdit {
            placeholder-text: "Ketik sesuatu di sini...";
            font-size: 24px;
            height: 45px;
            edited(text) => {
                root.input-data = text;
            }
        }

        Button {
            text: "PROSES SEKARANG";
            primary: true;
            height: 50px;
            clicked => {
                root.process-data(root.input-data);
            }
        }

        Rectangle {
            background: #1e1e1e;
            border-radius: 8px;
            height: 150px;
            
            VerticalBox {
                padding: 15px;
                Text {
                    text: "HASIL PROSES:";
                    color: #39ff14;
                    font-size: 24px;
                    font-weight: 800;
                }
                Text {
                    text: root.result-data;
                    color: #ffffff;
                    font-size: 24px;
                    wrap: word-wrap;
                }
            }
        }

        Text {
            text: "VROH CORE v4.5 - ULTRA LITE";
            color: #444444;
            font-size: 24px;
            horizontal-alignment: center;
        }
    }
}
