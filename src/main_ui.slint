import { Button, VerticalBox, ScrollView, HorizontalBox, LineEdit } from "std-widgets.slint";

export global OdfizTheme {
    in property <color> bg-outer: #C0C4CC;
    in property <color> card-bg: #ffffff;
    in property <color> terminal-bg: #1a1b26;
    in property <color> accent-color: #ff4d6d;
    in property <color> terminal-text: #a9b1d6;
    in property <length> safe-area-top: 65px;
}

export component AppWindow inherits Window {
    title: "Odfiz Native Core";
    background: OdfizTheme.bg-outer;
    default-font-family: "monospace"; // Seragamkan semua font
    
    // Properti status-text sekarang menampung seluruh history
    in-out property <string> log-history: "System initialized...";
    callback process-data(string);

    ScrollView {
        viewport-height: main-layout.preferred-height;
        
        main-layout := VerticalBox {
            padding: 20px;
            padding-top: OdfizTheme.safe-area-top;
            spacing: 15px;

            // 1. TERMINAL LOG (SEKARANG DI ATAS)
            Rectangle {
                background: OdfizTheme.terminal-bg;
                border-radius: 12px;
                height: 250px; // Dibuat lebih tinggi buat history
                clip: true;

                VerticalBox {
                    padding: 12px;
                    spacing: 8px;
                    
                    HorizontalBox {
                        alignment: start;
                        spacing: 6px;
                        Rectangle { width: 8px; height: 8px; border-radius: 4px; background: #444; }
                        Rectangle { width: 8px; height: 8px; border-radius: 4px; background: #444; }
                        Rectangle { width: 8px; height: 8px; border-radius: 4px; background: #444; }
                    }

                    ScrollView {
                        viewport-height: log-content.preferred-height;
                        log-content := TextInput {
                            text: root.log-history;
                            font-size: 13px;
                            color: OdfizTheme.terminal-text;
                            read-only: true;
                            wrap: word-wrap;
                            single-line: false;
                        }
                    }
                }
            }

            // 2. AREA INPUT (DI BAWAH TERMINAL)
            Rectangle {
                background: OdfizTheme.card-bg;
                border-radius: 20px;
                height: 150px;
                drop-shadow-blur: 15px;
                drop-shadow-color: #00000015;

                VerticalBox {
                    padding: 20px;
                    spacing: 15px;
                    input_field := LineEdit {
                        placeholder-text: "Enter data...";
                        height: 45px;
                        font-size: 15px;
                    }
                    HorizontalBox {
                        alignment: center;
                        Rectangle {
                            background: OdfizTheme.accent-color;
                            border-radius: 22px;
                            height: 44px;
                            width: 180px;
                            Text { text: "EXECUTE"; color: white; font-weight: 800; }
                            TouchArea { clicked => { root.process-data(input_field.text) } }
                        }
                    }
                }
            }

            Text {
                text: "ODFIZ NATIVE CORE V.5.0";
                font-size: 11px;
                color: #555;
                horizontal-alignment: center;
            }
        }
    }
}
