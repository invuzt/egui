import { Button, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Material";
    background: #FDF8FF; // Warna Surface (Tone pastel)
    
    in-out property <string> input-text;
    in-out property <string> status-text: "Sistem Ready";
    callback process-data(string);

    VerticalLayout {
        padding: 24px;
        padding-top: 70px;
        spacing: 16px;

        Text {
            text: "Odfiz Material";
            font-size: 32px;
            font-weight: 500; // Material You lebih suka Medium weight
            color: #1C1B1F;
        }

        LineEdit {
            placeholder-text: "Input data...";
            height: 56px; // Tinggi standar Material
            text <=> root.input-text;
        }

        // Card dengan Tonal Color
        Rectangle {
            background: #EADDFF; // Primary Container Color
            border-radius: 28px; // Radius besar khas Material You
            height: 140px;
            
            VerticalLayout {
                padding: 20px;
                Text {
                    text: "STATUS";
                    font-size: 12px;
                    font-weight: 700;
                    color: #21005D;
                }
                Text {
                    text: root.status-text;
                    font-size: 16px;
                    color: #21005D;
                    wrap: word-wrap;
                }
            }
        }

        // Filled Button (M3 Style)
        Button {
            text: "Kirim Data";
            primary: true;
            height: 40px;
            clicked => { root.process-data(root.input-text); }
        }
    }
}
