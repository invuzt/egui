import { Button, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Modern UI";
    background: #F2F2F7; // iOS System Background
    default-font-family: "sans-serif";
    
    // Properti untuk komunikasi dengan Rust
    in-out property <string> input-text;
    in-out property <string> status-text: "Sistem Ready - Performa Maksimal";
    callback process-data(string);

    VerticalLayout {
        padding: 24px;
        padding-top: 70px;
        spacing: 25px;
        alignment: start;

        Text {
            text: "Odfiz Core";
            font-size: 32px;
            font-weight: 700;
            color: #000000;
            horizontal-alignment: center;
        }

        // Input Field Style iOS
        LineEdit {
            placeholder-text: "Masukkan data...";
            height: 50px;
            text <=> root.input-text;
        }

        // Dashboard Card iOS Style
        Rectangle {
            background: #FFFFFF;
            border-radius: 14px;
            height: 130px;
            
            VerticalLayout {
                padding: 20px;
                spacing: 12px;
                Text {
                    text: "STATUS LOG";
                    font-size: 13px;
                    font-weight: 600;
                    color: #8E8E93; // iOS Secondary Label
                }
                Text {
                    text: root.status-text;
                    font-size: 17px;
                    font-weight: 500;
                    color: #000000;
                    wrap: word-wrap;
                }
            }
        }

        // Button iOS Style (Blue)
        Button {
            text: "PROSES DATA";
            primary: true;
            height: 54px;
            clicked => {
                root.process-data(root.input-text);
            }
        }
    }
}
