import { Button, VerticalBox, ScrollView, HorizontalBox, LineEdit } from "std-widgets.slint";

export global OdfizTheme {
    in property <color> bg-color: #F8F9FA;
    in property <color> card-bg: #EEF1F6;
    in property <color> text-primary: #202124;
    in property <color> text-secondary: #5f6368;
    in property <color> accent-color: #005FB8;
    in property <color> text-on-accent: #ffffff;
    
    in property <length> font-size-h1: 28px;
    in property <length> font-size-h2: 18px;
    in property <length> font-size-body: 14px;
    
    in property <length> card-radius: 24px;
    in property <length> button-radius: 20px;
    in property <length> status-bar-margin: 35px; 
}

component OdfizButton inherits Rectangle {
    in property <string> text;
    in property <bool> has-icon: false;
    callback clicked();

    background: OdfizTheme.accent-color;
    border-radius: OdfizTheme.button-radius;
    height: 40px;
    width: txt.preferred-width + (has-icon ? 50px : 40px);

    txt := Text {
        text: root.text;
        color: OdfizTheme.text-on-accent;
        font-size: OdfizTheme.font-size-body;
        font-weight: 700;
    }

    TouchArea {
        clicked => { root.clicked() }
    }
}

export component AppWindow inherits Window {
    title: "Odfiz Processor";
    background: OdfizTheme.bg-color;
    default-font-family: "sans-serif";
    
    in-out property <string> result-display: "Ready to process...";
    callback process-data(string);

    VerticalBox {
        padding-left: 16px;
        padding-right: 16px;
        
        // Header
        Rectangle {
            height: 60px + OdfizTheme.status-bar-margin;
            padding-top: OdfizTheme.status-bar-margin;
            
            Text {
                text: "Odfiz Processor";
                font-size: OdfizTheme.font-size-h1;
                color: OdfizTheme.text-primary;
                font-weight: 700;
                x: 0;
            }
        }

        ScrollView {
            VerticalBox {
                spacing: 12px;
                padding-bottom: 20px;

                // CARD INPUT
                Rectangle {
                    background: OdfizTheme.card-bg;
                    border-radius: OdfizTheme.card-radius;
                    padding: 20px;

                    VerticalBox {
                        spacing: 12px;
                        Text {
                            text: "Start Data Processing";
                            font-size: OdfizTheme.font-size-h2;
                            color: OdfizTheme.text-primary;
                        }
                        
                        // Cara penulisan ID yang benar (id := Element)
                        input_field := LineEdit {
                            placeholder-text: "Ketik data di sini...";
                            height: 45px;
                        }

                        HorizontalBox {
                            alignment: start;
                            OdfizButton {
                                text: "PROSES DATA";
                                clicked => { root.process-data(input_field.text) }
                            }
                        }
                    }
                }

                // CARD HASIL
                Rectangle {
                    background: OdfizTheme.card-bg;
                    border-radius: OdfizTheme.card-radius;
                    padding: 20px;

                    VerticalBox {
                        spacing: 8px;
                        Text {
                            text: "Hasil Pemrosesan";
                            font-size: OdfizTheme.font-size-h2;
                            color: OdfizTheme.text-primary;
                        }
                        
                        Rectangle {
                            background: #ffffff;
                            border-radius: 12px;
                            height: 100px;
                            padding: 15px;
                            Text {
                                text: root.result-display;
                                color: #333333;
                                font-size: 16px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
                
                Text {
                    text: "ODFIZ VROH v4.6 - MATERIAL ENGINE";
                    color: #bdbdbd;
                    font-size: 10px;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
