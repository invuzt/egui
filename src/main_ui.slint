import { Button, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "UI Elements";
    background: #F2F2F7;
    width: 400px;
    height: 800px;

    in-out property <bool> switch-on: true;
    in-out property <int> stepper-val: 0;
    in-out property <float> slider-val: 0.5; // 0.0 sampai 1.0

    ScrollView {
        VerticalBox {
            padding: 20px;
            spacing: 20px;
            alignment: start;

            Text {
                text: "UI elements";
                font-size: 34px;
                font-weight: 700;
                color: black;
            }

            // Group 1: List Items
            VerticalBox {
                padding: 0;
                spacing: 0;
                Text { text: "Header"; color: #8E8E93; font-size: 13px; }
                Rectangle { height: 5px; } // Pengganti margin-bottom
                
                Rectangle {
                    background: white;
                    border-radius: 12px;
                    VerticalBox {
                        padding-left: 15px; padding-right: 15px; spacing: 0;
                        
                        HorizontalBox {
                            height: 44px;
                            Text { text: "Primary"; vertical-alignment: center; color: black; font-size: 17px; }
                            Text { text: ">"; horizontal-alignment: right; color: #C7C7CC; vertical-alignment: center; }
                        }
                        Rectangle { height: 1px; background: #E5E5EA; }
                        
                        HorizontalBox {
                            height: 44px;
                            Text { text: "Secondary"; vertical-alignment: center; color: black; font-size: 17px; }
                            Text { text: ">"; horizontal-alignment: right; color: #C7C7CC; vertical-alignment: center; }
                        }
                        Rectangle { height: 1px; background: #E5E5EA; }
                        
                        HorizontalBox {
                            height: 44px;
                            Text { text: "Tertiary"; vertical-alignment: center; color: black; font-size: 17px; }
                            Text { text: ">"; horizontal-alignment: right; color: #C7C7CC; vertical-alignment: center; }
                        }
                    }
                }
                Rectangle { height: 5px; }
                Text { text: "Footer text"; color: #8E8E93; font-size: 13px; }
            }

            // Single List Item
            Rectangle {
                background: white;
                border-radius: 12px;
                height: 50px;
                HorizontalBox {
                    padding-left: 15px; padding-right: 15px;
                    Text { text: "Single List Item"; vertical-alignment: center; color: black; font-size: 17px; }
                    HorizontalBox {
                        alignment: end;
                        spacing: 10px;
                        Text { text: "Detail"; color: #8E8E93; vertical-alignment: center; }
                        Text { text: ">"; color: #C7C7CC; vertical-alignment: center; }
                    }
                }
            }

            // Controls Group
            Rectangle {
                background: white;
                border-radius: 12px;
                VerticalBox {
                    padding-left: 15px; padding-right: 15px; spacing: 0;
                    HorizontalBox {
                        height: 50px;
                        Text { text: "Stepper"; vertical-alignment: center; color: black; font-size: 17px; }
                        HorizontalBox {
                            alignment: end;
                            Rectangle {
                                background: #E9E9EB;
                                border-radius: 8px;
                                width: 100px; height: 32px;
                                HorizontalBox {
                                    padding: 2px;
                                    Text { text: " - "; font-size: 20px; vertical-alignment: center; horizontal-alignment: center; TouchArea { clicked => { root.stepper-val -= 1 } } }
                                    Rectangle { width: 1px; background: #C7C7CC; }
                                    Text { text: " + "; font-size: 20px; vertical-alignment: center; horizontal-alignment: center; TouchArea { clicked => { root.stepper-val += 1 } } }
                                }
                            }
                        }
                    }
                    Rectangle { height: 1px; background: #E5E5EA; }
                    HorizontalBox {
                        height: 50px;
                        Text { text: "Switch"; vertical-alignment: center; color: black; font-size: 17px; }
                        Rectangle {
                            width: 51px; height: 31px;
                            border-radius: 16px;
                            background: root.switch-on ? #34C759 : #E9E9EB;
                            animate background { duration: 150ms; }
                            
                            Rectangle {
                                x: root.switch-on ? 22px : 2px;
                                y: 2px;
                                width: 27px; height: 27px;
                                border-radius: 14px;
                                background: white;
                                animate x { duration: 150ms; }
                            }
                            TouchArea { clicked => { root.switch-on = !root.switch-on } }
                        }
                    }
                }
            }

            // Slider
            Rectangle {
                background: white;
                border-radius: 12px;
                height: 60px;
                slider-container := HorizontalBox {
                    padding-left: 15px; padding-right: 15px;
                    spacing: 15px;
                    Text { text: "🐢"; vertical-alignment: center; }
                    
                    track := Rectangle {
                        height: 4px;
                        background: #E5E5EA;
                        border-radius: 2px;
                        y: (parent.height / 2) - 2px;
                        
                        Rectangle { 
                            width: parent.width * root.slider-val;
                            background: #007AFF;
                            height: 100%;
                            border-radius: 2px;
                        }
                        
                        handle := Rectangle {
                            x: (parent.width * root.slider-val) - (self.width / 2);
                            y: (parent.height / 2) - (self.height / 2);
                            width: 28px; height: 28px;
                            background: white;
                            border-radius: 14px;
                            border-width: 0.5px;
                            border-color: #00000020;
                            
                            ta := TouchArea {
                                moved => {
                                    if (self.pressed) {
                                        root.slider-val = Math.max(0, Math.min(1.0, (self.mouse-x + handle.x) / track.width));
                                    }
                                }
                            }
                        }
                    }
                    Text { text: "🐇"; vertical-alignment: center; }
                }
            }

            Rectangle {
                height: 55px;
                background: #007AFF;
                border-radius: 14px;
                Text {
                    text: "Large Button";
                    color: white;
                    font-size: 17px;
                    font-weight: 600;
                }
                TouchArea { clicked => { /* Action */ } }
            }
        }
    }
}
