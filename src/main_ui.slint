import { ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Premium";
    background: #FFFFFF; // Putih bersih
    width: 400px;
    height: 800px;

    in-out property <string> current-view: "home";

    // 1. HEADER MINIMALIS (STATIC)
    Rectangle {
        y: 0; z: 100;
        width: 100%; height: 110px;
        background: #FFFFFFEE; // Glassmorphism effect (semi-transparan)
        
        VerticalBox {
            padding-top: 55px; padding-left: 25px; padding-right: 25px;
            HorizontalBox {
                alignment: space-between;
                Text {
                    text: root.current-view == "home" ? "Overview" : "Service";
                    font-size: 28px;
                    font-weight: 800;
                    color: #1C1C1E;
                    letter-spacing: -0.5px;
                }
                // Tombol Back Minimalis
                if (root.current-view != "home") : Rectangle {
                    width: 40px; height: 40px; border-radius: 20px;
                    background: #F2F2F7;
                    Text { text: "✕"; color: #3A3A3C; font-weight: 700; }
                    TouchArea { clicked => { root.current-view = "home" } }
                }
            }
        }
    }

    // 2. CONTENT AREA
    ScrollView {
        padding-top: 110px;
        
        VerticalBox {
            padding: 25px;
            spacing: 20px;

            if (root.current-view == "home") : VerticalBox {
                spacing: 25px;
                
                // CARD PREMIUM (Efek bayangan halus)
                Rectangle {
                    height: 180px;
                    background: #1C1C1E; // Dark Mode Card
                    border-radius: 24px;
                    
                    VerticalBox {
                        padding: 25px;
                        alignment: space-between;
                        Text { text: "Total Balance"; color: #8E8E93; font-size: 14px; }
                        Text { text: "$ 12,450.00"; color: white; font-size: 32px; font-weight: 700; }
                        HorizontalBox {
                            Rectangle {
                                width: 90px; height: 32px; border-radius: 16px;
                                background: #FFFFFF20;
                                Text { text: "Details"; color: white; font-size: 12px; }
                            }
                        }
                    }
                }

                Text { text: "Features"; color: #1C1C1E; font-size: 18px; font-weight: 700; }

                // GRID MENU MINIMALIS
                HorizontalBox {
                    spacing: 15px;
                    // Feature 1
                    Rectangle {
                        height: 120px; background: #F9F9F9; border-radius: 20px;
                        border-width: 1px; border-color: #F2F2F7;
                        VerticalBox {
                            padding: 20px; alignment: space-between;
                            Text { text: "🧮"; font-size: 24px; }
                            Text { text: "Calculator"; color: #1C1C1E; font-size: 14px; font-weight: 600; }
                        }
                        TouchArea { clicked => { root.current-view = "calc" } }
                    }
                    // Feature 2
                    Rectangle {
                        height: 120px; background: #F9F9F9; border-radius: 20px;
                        border-width: 1px; border-color: #F2F2F7;
                        VerticalBox {
                            padding: 20px; alignment: space-between;
                            Text { text: "📷"; font-size: 24px; }
                            Text { text: "Camera"; color: #1C1C1E; font-size: 14px; font-weight: 600; }
                        }
                        TouchArea { clicked => { root.current-view = "camera" } }
                    }
                }
            }

            if (root.current-view == "calc") : VerticalBox {
                Rectangle {
                    height: 400px; background: #F2F2F7; border-radius: 24px;
                    Text { text: "Calculator UI in development"; color: #8E8E93; }
                }
            }
        }
    }
}
