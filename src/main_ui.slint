import { Button, VerticalBox, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Processor";
    background: #F8F9FA; // Light Gray / White
    default-font-family: "sans-serif";

    in-out property <string> input-data: "";
    in-out property <string> result-data: "Menunggu data...";

    callback process-data(string);

    VerticalBox {
        padding: 30px;
        spacing: 20px;
        alignment: start;

        Text {
            text: "Odfiz Processor";
            color: #202124;
            font-size: 24px;
            font-weight: 700;
        }

        Text {
            text: "Ketik data yang ingin diproses:";
            color: #5f6368;
            font-size: 14px;
        }

        LineEdit {
            placeholder-text: "Contoh: Nama atau Kode...";
            height: 50px;
            edited(t) => { root.input-data = t; }
        }

        Button {
            text: "PROSES DATA";
            height: 50px;
            clicked => { root.process-data(root.input-data) }
        }

        Rectangle {
            background: #ffffff;
            border-radius: 12px;
            border-width: 1px;
            border-color: #dadce0;
            height: 150px;
            
            VerticalBox {
                padding: 15px;
                Text {
                    text: "HASIL AKHIR:";
                    color: #1a73e8; // Android Blue
                    font-size: 11px;
                    font-weight: 800;
                }
                Text {
                    text: root.result-data;
                    color: #202124;
                    font-size: 16px;
                    wrap: word-wrap;
                }
            }
        }

        Text {
            text: "ODFIZ VROH v4.5 - LIGHT ENGINE";
            color: #bdc1c6;
            font-size: 10px;
            horizontal-alignment: center;
        }
    }
}
