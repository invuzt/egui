import { Button, CheckBox, ComboBox, Slider, LineEdit, VerticalBox, HorizontalBox, ScrollView, TabWidget } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Dynamic Showcase";
    preferred-width: 400px;
    preferred-height: 800px;

    // --- LOGIKA TEMA DINAMIS ---
    in-out property <color> theme-bg: #f2f2f7;
    in-out property <color> card-bg: #ffffff;
    in-out property <color> accent-color: #007aff; // Default Blue (Cupertino)
    in-out property <length> theme-radius: 12px;
    in-out property <string> current-theme: "Cupertino";

    // Fungsi untuk ganti tema saat ComboBox berubah
    function change-theme(name: string) {
        root.current-theme = name;
        if (name == "Cupertino") {
            root.theme-bg = #f2f2f7;
            root.accent-color = #007aff;
            root.theme-radius = 12px;
            root.card-bg = #ffffff;
        } else if (name == "Material") {
            root.theme-bg = #fafafa;
            root.accent-color = #6200ee; // Purple Material
            root.theme-radius = 4px;
            root.card-bg = #ffffff;
        } else { // Dark Mode
            root.theme-bg = #1c1c1e;
            root.accent-color = #ff9f43;
            root.theme-radius = 16px;
            root.card-bg = #2c2c2e;
        }
    }

    background: root.theme-bg;

    VerticalBox {
        padding-top: 60px;
        padding-left: 20px;
        padding-right: 20px;
        spacing: 20px;

        Text {
            text: root.current-theme + " Mode";
            font-size: 28px;
            font-weight: 800;
            color: root.current-theme == "Dark" ? white : black;
        }

        // Dropdown Ganti Tema (REAL TIME!)
        ComboBox {
            model: ["Cupertino", "Material", "Dark"];
            current-value: root.current-theme;
            selected(val) => { root.change-theme(val) }
        }

        TabWidget {
            Tab {
                title: "Showcase";
                Rectangle {
                    background: root.card-bg;
                    border-radius: root.theme-radius;
                    VerticalBox {
                        padding: 20px;
                        spacing: 20px;
                        
                        Text { 
                            text: "Dynamic Style"; 
                            color: root.current-theme == "Dark" ? #cccccc : #8e8e93; 
                        }

                        // Tombol yang warnanya ikut tema
                        Rectangle {
                            height: 45px;
                            background: root.accent-color;
                            border-radius: root.theme-radius;
                            Text { text: "Adaptive Button"; color: white; font-weight: 700; }
                            TouchArea { clicked => { /* aksi */ } }
                        }

                        Slider { value: 40; }
                        
                        LineEdit { 
                            placeholder-text: "Input field...";
                        }
                    }
                }
            }
        }
    }
}
