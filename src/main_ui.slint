import { Button, VerticalBox, ScrollView, HorizontalBox, LineEdit } from "std-widgets.slint";

export global OdfizTheme {
    // --- GANTI WARNA DI SINI BIAR JADI ODFIZ CORE ---
    in property <color> bg-color: #0c0c0c;       // Hitam pekat
    in property <color> card-bg: #1a1a1a;       // Abu gelap untuk Card
    in property <color> accent-color: #ff4d6d;  // Pink-Merah khas Odfiz
    in property <color> text-primary: #ffffff;  // Putih bersih
    in property <color> text-secondary: #888888;
    in property <length> status-bar-margin: 35px;
}

component OdfizButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    background: OdfizTheme.accent-color;
    border-radius: 12px; // Gaya Odfiz lebih kotak-elegan dibanding Shizuku
    height: 48px;
    width: txt.preferred-width + 60px;

    txt := Text {
        text: root.text;
        color: white;
        font-weight: 800; // Lebih tebal
        font-size: 16px;
    }

    TouchArea { clicked => { root.clicked() } }
}

export component AppWindow inherits Window {
    title: "Odfiz Core Engine";
    background: OdfizTheme.bg-color;
    
    in-out property <string> result-display: "SYSTEM ONLINE";
    callback process-data(string);

    VerticalBox {
        padding-left: 20px;
        padding-right: 20px;
        spacing: 0;

        // HEADER
        VerticalBox {
            padding-top: OdfizTheme.status-bar-margin;
            Rectangle {
                height: 80px;
                Text {
                    text: "ODFIZ CORE";
                    font-size: 24px;
                    font-weight: 900;
                    color: OdfizTheme.accent-color; // Judul jadi merah
                    letter-spacing: 2px;
                    x: 0;
                }
            }
        }

        ScrollView {
            VerticalBox {
                spacing: 20px;
                padding-bottom: 20px;

                // CARD GAYA ODFIZ (Ada aksen garis di samping)
                Rectangle {
                    background: OdfizTheme.card-bg;
                    border-radius: 16px;
                    
                    // Garis merah tipis di samping kiri (ciri khas Odfiz Tech)
                    Rectangle {
                        width: 4px;
                        height: parent.height - 30px;
                        background: OdfizTheme.accent-color;
                        x: 0;
                        border-radius: 2px;
                    }

                    VerticalBox {
                        padding: 25px;
                        spacing: 15px;
                        
                        Text { text: "INPUT ENGINE"; font-size: 14px; color: OdfizTheme.text-secondary; font-weight: 700; }
                        
                        Rectangle {
                            background: #252525;
                            border-radius: 8px;
                            height: 50px;
                            input_field := LineEdit {
                                placeholder-text: "Enter data...";
                                font-size: 16px;
                            }
                        }

                        OdfizButton {
                            text: "REFRESH / PROCESS";
                            clicked => { root.process-data(input_field.text) }
                        }
                    }
                }

                // STATUS CARD
                Rectangle {
                    background: OdfizTheme.card-bg;
                    border-radius: 16px;
                    VerticalBox {
                        padding: 20px;
                        Text { text: "SYSTEM LOG"; font-weight: 700; color: OdfizTheme.text-secondary; }
                        Rectangle {
                            height: 100px;
                            Text { 
                                text: root.result-display; 
                                color: #00ff88; // Hijau neon buat status
                                font-family: "monospace";
                                font-size: 18px;
                            }
                        }
                    }
                }
            }
        }
    }
}
