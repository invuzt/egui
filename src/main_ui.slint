import { Button, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "UI Elements";
    background: #F2F2F7; // iOS Light Gray Background
    width: 400px;
    height: 800px;

    // State untuk komponen agar interaktif
    in-out property <bool> switch-on: true;
    in-out property <int> stepper-val: 0;
    in-out property <float> slider-val: 50.0;

    ScrollView {
        VerticalBox {
            padding: 20px;
            spacing: 20px;
            alignment: start;

            // Header Title
            Text {
                text: "UI elements";
                font-size: 34px;
                font-weight: 700;
                color: black;
            }

            // Group 1: List Items
            VerticalBox {
                padding: 0;
                spacing: 0;
                Text { text: "Header"; color: #8E8E93; font-size: 13px; margin-bottom: 5px; }
                
                Rectangle {
                    background: white;
                    border-radius: 12px;
                    VerticalBox {
                        padding-left: 15px; padding-right: 15px;
                        // Primary
                        HorizontalBox {
                            height: 44px;
                            Text { text: "Primary"; vertical-alignment: center; color: black; font-size: 17px; }
                            Text { text: ">"; horizontal-alignment: end; color: #C7C7CC; }
                        }
                        Rectangle { height: 1px; background: #E5E5EA; } // Divider
                        // Secondary
                        HorizontalBox {
                            height: 44px;
                            Text { text: "Secondary"; vertical-alignment: center; color: black; font-size: 17px; }
                            Text { text: ">"; horizontal-alignment: end; color: #C7C7CC; }
                        }
                        Rectangle { height: 1px; background: #E5E5EA; } // Divider
                        // Tertiary
                        HorizontalBox {
                            height: 44px;
                            Text { text: "Tertiary"; vertical-alignment: center; color: black; font-size: 17px; }
                            Text { text: ">"; horizontal-alignment: end; color: #C7C7CC; }
                        }
                    }
                }
                Text { text: "Footer text"; color: #8E8E93; font-size: 13px; margin-top: 5px; }
            }

            // Single List Item
            Rectangle {
                background: white;
                border-radius: 12px;
                height: 50px;
                HorizontalBox {
                    padding-left: 15px; padding-right: 15px;
                    Text { text: "Single List Item"; vertical-alignment: center; color: black; font-size: 17px; }
                    HorizontalBox {
                        alignment: end;
                        spacing: 10px;
                        Text { text: "Detail"; color: #8E8E93; vertical-alignment: center; }
                        Text { text: ">"; color: #C7C7CC; vertical-alignment: center; }
                    }
                }
            }

            // Controls Group (Stepper & Switch)
            Rectangle {
                background: white;
                border-radius: 12px;
                VerticalBox {
                    padding-left: 15px; padding-right: 15px;
                    // Stepper
                    HorizontalBox {
                        height: 50px;
                        Text { text: "Stepper"; vertical-alignment: center; color: black; font-size: 17px; }
                        HorizontalBox {
                            alignment: end;
                            Rectangle {
                                background: #E9E9EB;
                                border-radius: 8px;
                                width: 100px; height: 32px;
                                HorizontalBox {
                                    spacing: 0;
                                    Text { text: " - "; font-size: 20px; TouchArea { clicked => { root.stepper-val -= 1 } } }
                                    Rectangle { width: 1px; background: #C7C7CC; margin-top: 5px; margin-bottom: 5px; }
                                    Text { text: " + "; font-size: 20px; TouchArea { clicked => { root.stepper-val += 1 } } }
                                }
                            }
                        }
                    }
                    Rectangle { height: 1px; background: #E5E5EA; }
                    // Switch
                    HorizontalBox {
                        height: 50px;
                        Text { text: "Switch"; vertical-alignment: center; color: black; font-size: 17px; }
                        Rectangle {
                            width: 51px; height: 31px;
                            border-radius: 16px;
                            background: root.switch-on ? #34C759 : #E9E9EB;
                            animate background { duration: 200ms; }
                            
                            Rectangle { // Thumb
                                x: root.switch-on ? 22px : 2px;
                                width: 27px; height: 27px;
                                border-radius: 14px;
                                background: white;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: #00000020;
                                animate x { duration: 200ms; easing: ease-in-out; }
                            }
                            TouchArea { clicked => { root.switch-on = !root.switch-on } }
                        }
                    }
                }
            }

            // Slider (Tortoise & Hare)
            Rectangle {
                background: white;
                border-radius: 12px;
                height: 60px;
                HorizontalBox {
                    padding-left: 15px; padding-right: 15px;
                    spacing: 15px;
                    Text { text: "🐢"; vertical-alignment: center; }
                    // Custom Slider Track
                    Rectangle {
                        height: 4px;
                        background: #E5E5EA;
                        border-radius: 2px;
                        y: (parent.height / 2) - 2px;
                        Rectangle { // Active Track
                            width: root.slider-val * 1%;
                            background: #007AFF;
                            height: 100%;
                            border-radius: 2px;
                        }
                        Rectangle { // Handle
                            x: (root.slider-val * 1%) - 14px;
                            y: -12px;
                            width: 28px; height: 28px;
                            background: white;
                            border-radius: 14px;
                            drop-shadow-blur: 4px;
                            drop-shadow-color: #00000030;
                            TouchArea {
                                moved => {
                                    if (self.pressed) {
                                        root.slider-val = Math.max(0, Math.min(100, (root.slider-val + (touch-x - self.width/2) / 2)));
                                    }
                                }
                            }
                        }
                    }
                    Text { text: "🐇"; vertical-alignment: center; }
                }
            }

            // Large Blue Button
            Rectangle {
                height: 55px;
                background: #007AFF;
                border-radius: 27px;
                Text {
                    text: "Large Button";
                    color: white;
                    font-size: 17px;
                    font-weight: 600;
                }
                TouchArea { clicked => { /* Action */ } }
            }
        }
    }
}
