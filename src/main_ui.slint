import { Button, VerticalBox, ScrollView, HorizontalBox, LineEdit } from "std-widgets.slint";

export global OdfizTheme {
    in property <color> bg-color: #0c0c0c;
    in property <color> card-bg: #1a1a1a;
    in property <color> accent-color: #ff4d6d;
    in property <color> text-primary: #ffffff;
    in property <color> text-secondary: #888888;
    in property <color> text-input: #e0e0e0; // Warna terang khusus buat input
    in property <color> status-green: #00ff88;
    in property <length> status-bar-margin: 35px;
}

component OdfizButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    background: touch.pressed ? OdfizTheme.accent-color.darker(20%) : (touch.has-hover ? OdfizTheme.accent-color.brighter(10%) : OdfizTheme.accent-color);
    border-radius: 12px;
    height: 48px;
    width: 220px;
    animate background { duration: 150ms; }
    txt := Text {
        text: root.text;
        color: white;
        font-weight: 800;
        font-size: 14px;
        letter-spacing: 1px;
    }
    touch := TouchArea { clicked => { root.clicked() } }
}

export component AppWindow inherits Window {
    title: "Odfiz Core Engine";
    background: OdfizTheme.bg-color;
    in-out property <string> status-text: "SYSTEM ONLINE";
    callback process-data(string);

    VerticalBox {
        padding-left: 20px;
        padding-right: 20px;
        spacing: 0;

        // HEADER
        VerticalBox {
            padding-top: OdfizTheme.status-bar-margin;
            padding-bottom: 10px;
            alignment: center;
            Text {
                text: "ODFIZ CORE";
                font-size: 26px;
                font-weight: 900;
                color: OdfizTheme.accent-color;
                letter-spacing: 3px;
                horizontal-alignment: center;
            }
        }

        ScrollView {
            VerticalBox {
                spacing: 20px;
                padding-bottom: 20px;

                Rectangle {
                    background: OdfizTheme.card-bg;
                    border-radius: 16px;
                    
                    VerticalBox {
                        padding: 25px;
                        spacing: 18px;
                        
                        // --- FOKUS PERBAIKAN 1: STATUS TEXT WRAPPING ---
                        VerticalBox {
                            spacing: 4px;
                            padding: 0;
                            Text { 
                                text: root.status-text; 
                                font-size: 12px; 
                                font-weight: 800; 
                                color: OdfizTheme.status-green; 
                                horizontal-alignment: left;
                                // === TAMBAHKAN INI ===
                                wrap: word-wrap; // Teks bakal turun jika terlalu panjang
                            }
                            Text { 
                                text: "CORE ENGINE INTERFACE"; 
                                font-size: 16px; 
                                font-weight: 700; 
                                color: OdfizTheme.text-primary; 
                            }
                        }

                        VerticalBox {
                            spacing: 8px;
                            padding: 0;
                            Text { text: "ENTER DATA"; font-size: 11px; color: OdfizTheme.text-secondary; font-weight: 700; }
                            Rectangle {
                                background: #252525;
                                border-radius: 8px;
                                height: 50px;
                                // --- FOKUS PERBAIKAN 2: INPUT TEXT COLOR ---
                                input_field := LineEdit {
                                    placeholder-text: "Type here...";
                                    font-size: 15px;
                                    width: 100%;
                                    height: 100%;
                                    // === TAMBAHKAN INI ===
                                    color: OdfizTheme.text-input; // Warna teks input jadi terang
                                }
                            }
                        }

                        HorizontalBox {
                            alignment: center;
                            OdfizButton {
                                text: "EXECUTE PROCESS";
                                clicked => { root.process-data(input_field.text) }
                            }
                        }
                    }
                }

                Text {
                    text: "V.4.7 NATIVE ENGINE";
                    font-size: 10px;
                    color: #444;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
