import { Button, CheckBox, ComboBox, Slider, LineEdit, StandardListView, TabWidget, GroupBox, VerticalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Cupertino Gallery";
    // Pakai tema cupertino secara eksplisit di sini jika didukung sistem, 
    // atau biarkan default native mengaturnya.
    preferred-width: 400px;
    preferred-height: 800px;
    background: #f2f2f7; // Warna khas background iOS

    ScrollView {
        VerticalBox {
            padding: 20px;
            spacing: 15px;

            Text {
                text: "Widget Gallery";
                font-size: 28px;
                font-weight: 800;
                color: #000000;
            }

            // Bagian Tombol
            GroupBox {
                title: "Buttons";
                VerticalBox {
                    Button { text: "Regular Button"; }
                    Button { text: "Primary Button"; primary: true; }
                }
            }

            // Input & Control
            GroupBox {
                title: "Controls";
                VerticalBox {
                    spacing: 10px;
                    CheckBox { text: "Widgets Enabled"; checked: true; }
                    ComboBox {
                        model: ["Option 1", "Option 2", "Option 3"];
                        current-value: "Select Something";
                    }
                    Slider { value: 50; minimum: 0; maximum: 100; }
                }
            }

            // Text Input
            GroupBox {
                title: "Input Fields";
                VerticalBox {
                    LineEdit { placeholder-text: "Enter some text..."; }
                    LineEdit { placeholder-text: "Password"; input-type: password; }
                }
            }

            // Tabs
            GroupBox {
                title: "Tab Navigation";
                TabWidget {
                    Tab {
                        title: "Tab 1";
                        VerticalBox {
                            alignment: center;
                            Text { text: "Content of Tab 1"; horizontal-alignment: center; }
                            Button { text: "Click Me"; }
                        }
                    }
                    Tab {
                        title: "Tab 2";
                        Text { text: "Content of Tab 2"; horizontal-alignment: center; }
                    }
                    Tab {
                        title: "Tab 3";
                        Text { text: "Content of Tab 3"; horizontal-alignment: center; }
                    }
                }
            }
        }
    }
}
