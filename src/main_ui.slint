import { Button, VerticalBox, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Native Processor";
    in-out property <bool> is-dark-mode: true;
    background: is-dark-mode ? #121212 : #f5f5f5;
    default-font-family: "sans-serif";

    in-out property <string> input-data: "";
    in-out property <string> result-data: "Ready...";

    callback process-data(string);

    VerticalBox {
        padding: 30px;
        spacing: 20px;
        
        Text {
            text: "Odfiz Processor";
            color: root.is-dark-mode ? #ffffff : #000000;
            font-size: 24px;
            font-weight: 700;
        }

        LineEdit {
            placeholder-text: "Ketik di sini...";
            height: 50px;
            edited(t) => { root.input-data = t; }
        }

        Button {
            text: "PROSES DATA";
            height: 50px;
            clicked => { root.process-data(root.input-data) }
        }

        Rectangle {
            background: root.is-dark-mode ? #1e1e1e : #ffffff;
            border-radius: 12px;
            height: 120px;
            VerticalBox {
                padding: 15px;
                Text { text: "HASIL:"; color: #39ff14; font-size: 11px; }
                Text {
                    text: root.result-data;
                    color: root.is-dark-mode ? #ffffff : #333333;
                    font-size: 16px;
                    wrap: word-wrap;
                }
            }
        }
    }
}
