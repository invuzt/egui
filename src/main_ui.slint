import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Secure";
    background: #1a1a2e;
    width: 400px;
    height: 600px;

    // Pastikan nama callback & property ini SAMA PERSIS dengan di Rust
    callback secure-now();
    callback refresh-pulse();
    in-out property <string> status-text: "Odfiz System Ready";
    in-out property <string> pulse-info: "RAM: --MB";

    VerticalBox {
        padding: 30px;
        spacing: 20px;
        alignment: start;

        // Logo dari ic_launcher (Kita ambil dari assets/res)
        // Slint bisa baca file langsung selama pathnya benar saat build
        Image {
            source: @image-url("../app/src/main/res/mipmap-hdpi/ic_launcher.png");
            width: 80px;
            height: 80px;
            horizontal-alignment: center;
        }

        // Monitoring Area (Modern Box)
        Rectangle {
            height: 80px;
            background: #0f3460;
            border-radius: 12px;
            Text {
                text: root.pulse-info;
                color: #00d2ff;
                font-size: 18px;
                font-weight: 700;
            }
        }

        Rectangle {
            background: #16213e;
            border-radius: 8px;
            padding: 10px;
            Text {
                text: root.status-text;
                color: #eeeeee;
                font-size: 14px;
                wrap: word;
                horizontal-alignment: center;
            }
        }

        Button {
            text: "SECURE DATA";
            primary: true;
            height: 50px;
            clicked => { root.secure-now() }
        }

        Button {
            text: "CHECK SYSTEM";
            height: 50px;
            clicked => { root.refresh-pulse() }
        }
    }
}
