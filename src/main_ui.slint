import { Button, CheckBox, ComboBox, Slider, LineEdit, VerticalBox, HorizontalBox, ScrollView, GroupBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Cupertino Gallery";
    preferred-width: 400px;
    preferred-height: 800px;
    background: #f2f2f7; 

    ScrollView {
        VerticalBox {
            padding-top: 60px;
            padding-left: 20px;
            padding-right: 20px;
            spacing: 20px;

            Text {
                text: "Cupertino Style";
                font-size: 32px;
                font-weight: 800;
                color: #000000;
            }

            GroupBox {
                title: "Action Buttons";
                VerticalBox {
                    spacing: 10px;
                    Button { text: "Cupertino Button"; primary: true; }
                    Button { text: "Secondary Action"; }
                }
            }

            GroupBox {
                title: "Selection Controls";
                VerticalBox {
                    spacing: 15px;
                    HorizontalBox {
                        padding: 0;
                        alignment: start;
                        CheckBox { text: "Enable Feature"; checked: true; }
                    }
                    Slider { value: 50; }
                    ComboBox {
                        model: ["Item 1", "Item 2", "Item 3"];
                        current-value: "Item 1";
                    }
                }
            }

            GroupBox {
                title: "Text Entry";
                LineEdit { placeholder-text: "iOS style input..."; }
            }
            
            // Spacer agar tidak mentok bawah
            Rectangle { height: 50px; }
        }
    }
}
