import { Button, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Data Engine";
    background: #1a1a2e;
    width: 400px;
    height: 700px;

    callback process-million-data();
    callback search-data(string);
    
    in-out property <string> status-text: "System Idle";
    in-out property <string> engine-info: "Engine: Ready";
    in-out property <float> ram-percent: 0.0;

    ScrollView {
        VerticalBox {
            padding: 25px;
            spacing: 20px;

            Image {
                source: @image-url("../app/src/main/res/mipmap-hdpi/ic_launcher.png");
                width: 80px;
                height: 80px;
                horizontal-alignment: center;
            }

            Rectangle {
                height: 120px;
                background: #0f3460;
                border-radius: 12px;
                VerticalBox {
                    alignment: center;
                    Text { text: "RUST DATA ENGINE"; color: #ff9f43; font-weight: 800; horizontal-alignment: center; }
                    Text { text: root.engine-info; color: #00d2ff; font-size: 18px; horizontal-alignment: center; }
                    Rectangle {
                        height: 8px;
                        background: #16213e;
                        border-radius: 4px;
                        Rectangle {
                            x: 0; width: parent.width * root.ram-percent;
                            background: #4cd137; border-radius: 4px;
                        }
                    }
                }
            }

            // Input area lebih aman
            VerticalBox {
                spacing: 5px;
                Text { text: "Masukkan ID Pencarian:"; color: white; font-size: 12px; }
                input := TextInput {
                    font-size: 18px;
                    color: white;
                    // Gunakan properti text langsung
                }
                Button {
                    text: "CARI DATA";
                    clicked => { root.search-data(input.text) }
                }
            }

            Button {
                text: "GENERATE & PROCESS 1M DATA";
                primary: true;
                height: 50px;
                clicked => { root.process-million-data() }
            }

            Rectangle {
                background: #000000;
                border-radius: 5px;
                height: 120px;
                VerticalBox {
                    padding: 10px;
                    Text { text: root.status-text; color: #00ff00; font-family: "monospace"; font-size: 11px; wrap: word-wrap; }
                }
            }
        }
    }
}
