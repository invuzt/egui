import { Button, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Data Engine v3";
    background: #1a1a2e;
    width: 400px;
    height: 750px;

    callback insert-external-data();
    callback search-data(string);
    callback save-database();
    
    in-out property <string> status: "Engine Ready";
    in-out property <string> preview: "No data in RAM";
    in-out property <int> total-data: 0;

    VerticalBox {
        padding: 20px;
        spacing: 15px;

        Text { text: "ODFIZ DATA CONTROLLER"; color: #ff9f43; font-weight: 800; horizontal-alignment: center; }

        Rectangle {
            height: 80px; background: #16213e; border-radius: 10px;
            VerticalBox {
                alignment: center;
                Text { text: "Total Data loaded: " + root.total-data; color: #00d2ff; font-weight: 700; }
                Text { text: root.status; color: #4cd137; font-size: 11px; }
            }
        }

        VerticalBox {
            spacing: 8px;
            Text { text: "Cari ID atau Nama:"; color: white; }
            input := TextInput { font-size: 16px; color: #00ff00; }
            Button { text: "CARI INSTAN"; primary: true; clicked => { root.search-data(input.text) } }
        }

        Rectangle {
            background: #0f3460; border-radius: 8px; height: 150px;
            ScrollView {
                padding: 10px; // Padding dipindah ke sini
                Text { 
                    text: root.preview; 
                    color: #eeeeee; 
                    font-family: "monospace"; 
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }
        }

        HorizontalBox {
            spacing: 10px;
            Button { text: "INSERT FILE"; clicked => { root.insert-external-data() } }
            Button { text: "SAVE TO DISK"; clicked => { root.save-database() } }
        }
    }
}
