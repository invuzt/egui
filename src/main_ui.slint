import { Button, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Crypto Miner Sim";
    background: #0d0d0d;
    preferred-width: 400px;
    preferred-height: 850px;

    in-out property <string> log-text: "[SYSTEM] Initializing nodes...\n[INFO] Connecting to Odfiz Pool...";
    in-out property <string> hashrate: "0.00 TH/s";
    in-out property <string> balance: "0.00000000";
    in-out property <float> progress: 0.0;
    in-out property <bool> is-mining: false;

    callback toggle-mining();

    VerticalBox {
        padding-top: 60px;
        padding-left: 20px;
        padding-right: 20px;
        spacing: 15px;

        // Header Stats
        Rectangle {
            height: 120px;
            background: #1a1a1a;
            border-radius: 12px;
            border-width: 1px;
            border-color: #39ff14; // Green Neon

            VerticalBox {
                alignment: center;
                Text { text: "MINING PROFITABILITY"; color: #888; font-size: 12px; }
                Text { text: root.balance + " BTC"; color: #39ff14; font-size: 28px; font-weight: 800; }
                Text { text: "HASHRATE: " + root.hashrate; color: #00d2ff; font-size: 14px; }
            }
        }

        // Live Graphic Simulation (Progress Bar)
        VerticalBox {
            spacing: 5px;
            Text { text: "BLOCK DISCOVERY PROGRESS"; color: #555; font-size: 10px; }
            Rectangle {
                height: 10px; background: #222; border-radius: 5px;
                Rectangle {
                    x: 0; width: parent.width * root.progress;
                    background: #39ff14; border-radius: 5px;
                    animate width { duration: 500ms; }
                }
            }
        }

        // Terminal Log (Paling Penting buat kesan "Serius")
        Rectangle {
            background: #000;
            border-radius: 8px;
            height: 300px;
            ScrollView {
                padding: 10px;
                Text { 
                    text: root.log-text; 
                    color: #00ff00; 
                    font-family: "monospace"; 
                    font-size: 11px; 
                    wrap: word-wrap;
                }
            }
        }

        // Action Button
        Button {
            text: root.is-mining ? "STOP MINER" : "START MINING ENGINE";
            primary: true;
            height: 50px;
            clicked => { root.toggle-mining() }
        }

        Text {
            text: "ODFIZ CORE ENGINE v4.0 - TESTNET ONLY";
            color: #444;
            font-size: 10px;
            horizontal-alignment: center;
        }
    }
}
