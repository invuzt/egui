import { Button, CheckBox, ComboBox, Slider, LineEdit, StandardListView, TabWidget, GroupBox, VerticalBox, ScrollView, ProgressIndicator } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Widget Gallery";
    preferred-width: 400px;
    preferred-height: 800px;
    background: #f2f2f7;

    ScrollView {
        VerticalBox {
            padding: 20px;
            spacing: 15px;

            Text {
                text: "Slint Widget Gallery";
                font-size: 26px;
                font-weight: 800;
                color: #1c1c1e;
            }

            GroupBox {
                title: "Buttons & Interaction";
                VerticalBox {
                    Button { text: "Regular Button"; }
                    Button { text: "Primary Button"; primary: true; }
                    CheckBox { text: "Widgets Enabled"; checked: true; }
                }
            }

            GroupBox {
                title: "Input & Selection";
                VerticalBox {
                    spacing: 10px;
                    LineEdit { placeholder-text: "Type something here..."; }
                    ComboBox {
                        model: ["Cupertino Style", "Material Style", "Native Style"];
                        current-value: "Cupertino Style";
                    }
                }
            }

            GroupBox {
                title: "Indicators & Sliders";
                VerticalBox {
                    spacing: 15px;
                    Text { text: "Progress: 65%"; color: #8e8e93; }
                    ProgressIndicator { progress: 65%; }
                    Slider { value: 42; minimum: 0; maximum: 100; }
                }
            }

            GroupBox {
                title: "Tab Navigation";
                TabWidget {
                    Tab {
                        title: "Controls";
                        VerticalBox {
                            padding: 10px;
                            Button { text: "Click in Tab 1"; }
                        }
                    }
                    Tab {
                        title: "Views";
                        Text { text: "ListView content goes here."; padding: 10px; }
                    }
                }
            }
            
            // Tambahkan jarak di bawah agar tidak mentok navigasi HP
            Rectangle { height: 40px; }
        }
    }
}
