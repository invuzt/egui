import { Button, VerticalBox, ScrollView, HorizontalBox, LineEdit } from "std-widgets.slint";

export global OdfizTheme {
    in property <color> bg-outer: #d1d5db;      // Abu-abu lebih gelap agar status bar kontras
    in property <color> card-bg: #ffffff;
    in property <color> accent-color: #ff4d6d;
    in property <color> text-primary: #1c1e21;
    in property <color> text-secondary: #606770;
    in property <color> status-green: #28a745;
    in property <length> status-bar-margin: 35px;
}

component OdfizButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    background: touch.pressed ? OdfizTheme.accent-color.darker(10%) : OdfizTheme.accent-color;
    border-radius: 25px;
    height: 45px;
    width: 200px;
    animate background { duration: 150ms; }
    
    txt := Text {
        text: root.text;
        color: white;
        font-weight: 800;
        font-size: 14px;
    }
    touch := TouchArea { clicked => { root.clicked() } }
}

export component AppWindow inherits Window {
    title: "Odfiz Processor";
    background: OdfizTheme.bg-outer; // Background luar lebih gelap
    in-out property <string> status-text: "SYSTEM ONLINE";
    callback process-data(string);

    // ScrollView adalah kunci agar UI bisa naik/digeser saat keyboard muncul
    ScrollView {
        viewport-height: main-layout.preferred-height;
        
        main-layout := VerticalBox {
            padding: 20px;
            padding-top: OdfizTheme.status-bar-margin;
            spacing: 20px;
            alignment: start;

            // CARD UTAMA: Langsung fokus ke Status dan Input
            Rectangle {
                background: OdfizTheme.card-bg;
                border-radius: 20px;
                drop-shadow-blur: 15px;
                drop-shadow-color: #00000020;

                VerticalBox {
                    padding: 25px;
                    spacing: 20px;
                    
                    // Status Text (Sekarang paling atas dan bisa wrap)
                    Text { 
                        text: root.status-text; 
                        font-size: 13px; 
                        font-weight: 800; 
                        color: OdfizTheme.status-green; 
                        wrap: word-wrap;
                        horizontal-alignment: left;
                    }

                    // INPUT AREA (Tanpa label tambahan, langsung ke intinya)
                    input_field := LineEdit {
                        placeholder-text: "Ketik data di sini...";
                        font-size: 16px;
                        height: 50px;
                        // LineEdit otomatis fokus dan keyboard muncul di Android
                    }

                    HorizontalBox {
                        alignment: center;
                        OdfizButton {
                            text: "RUN PROCESS";
                            clicked => { root.process-data(input_field.text) }
                        }
                    }
                }
            }

            // Keterangan versi taruh di bawah
            Text {
                text: "ODFIZ NATIVE V.4.7";
                font-size: 10px;
                color: #666;
                horizontal-alignment: center;
            }
        }
    }
}
