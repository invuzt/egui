import { Button, VerticalBox, HorizontalBox, ScrollView, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Super App";
    background: #F2F2F7;
    width: 400px;
    height: 800px;

    // State Navigasi: "home", "calc", "gallery", "camera"
    in-out property <string> current-view: "home";
    
    // Header Tetap (Static)
    header := Rectangle {
        y: 0;
        width: 100%;
        height: 100px;
        background: #F2F2F7;
        z: 100; // Pastikan di atas layer lain

        VerticalBox {
            padding-top: 45px; // AMAN DARI STATUS BAR
            padding-left: 20px;
            padding-right: 20px;
            
            HorizontalBox {
                Text {
                    text: root.current-view == "home" ? "UI Elements" : 
                          root.current-view == "calc" ? "Calculator" : "Feature";
                    font-size: 30px;
                    font-weight: 700;
                    color: black;
                }
                // Tombol Back jika tidak di Home
                if (root.current-view != "home") : Button {
                    text: "Back";
                    clicked => { root.current-view = "home" }
                }
            }
        }
    }

    // Area Konten (Bisa di-scroll)
    ScrollView {
        padding-top: 100px; // Beri ruang agar tidak tertutup header static

        if (root.current-view == "home") : VerticalBox {
            padding: 20px;
            spacing: 15px;
            
            // Menu Fitur
            Rectangle {
                background: white; border-radius: 12px;
                VerticalBox {
                    padding: 5px;
                    HorizontalBox { 
                        Text { text: "🧮 Calculator"; vertical-alignment: center; }
                        Button { text: "Open"; clicked => { root.current-view = "calc" } }
                    }
                    Rectangle { height: 1px; background: #E5E5EA; }
                    HorizontalBox { 
                        Text { text: "📷 Camera"; vertical-alignment: center; }
                        Button { text: "Open"; clicked => { root.current-view = "camera" } }
                    }
                }
            }
        }

        if (root.current-view == "calc") : VerticalBox {
            padding: 20px;
            Text { text: "Kalkulator Logic di sini..."; font-size: 20px; }
            // Tambahkan grid tombol kalkulator di sini nanti
        }

        if (root.current-view == "camera") : VerticalBox {
            padding: 20px;
            Rectangle {
                height: 300px;
                background: black;
                Text { text: "Camera Preview"; color: white; vertical-alignment: center; horizontal-alignment: center; }
            }
        }
    }
}
