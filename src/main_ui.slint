import { Button, VerticalBox, ScrollView, HorizontalBox, LineEdit } from "std-widgets.slint";

export global OdfizTheme {
    in property <color> bg-outer: #C0C4CC;
    in property <color> card-bg: #ffffff;
    in property <color> terminal-bg: #1a1b26;
    in property <color> accent-color: #ff4d6d;
    in property <color> terminal-text: #a9b1d6;
    in property <length> safe-area-top: 65px;
}

component OdfizButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    background: touch.pressed ? OdfizTheme.accent-color.darker(10%) : OdfizTheme.accent-color;
    border-radius: 25px;
    height: 45px;
    width: 180px;
    animate background { duration: 150ms; }
    Text { text: root.text; color: white; font-weight: 800; }
    touch := TouchArea { clicked => { root.clicked() } }
}

export component AppWindow inherits Window {
    title: "Odfiz Native Processor";
    background: OdfizTheme.bg-outer;
    in-out property <string> status-text: "ready to process...";
    callback process-data(string);

    ScrollView {
        viewport-height: main-layout.preferred-height;
        
        main-layout := VerticalBox {
            padding: 20px;
            padding-top: OdfizTheme.safe-area-top;
            spacing: 15px;

            // AREA INPUT
            Rectangle {
                background: OdfizTheme.card-bg;
                border-radius: 20px;
                height: 150px;
                drop-shadow-blur: 15px;
                drop-shadow-color: #00000015;

                VerticalBox {
                    padding: 20px;
                    spacing: 15px;
                    input_field := LineEdit {
                        placeholder-text: "Input command...";
                        height: 45px;
                    }
                    HorizontalBox {
                        alignment: center;
                        OdfizButton {
                            text: "RUN ENGINE";
                            clicked => { root.process-data(input_field.text) }
                        }
                    }
                }
            }

            // AREA TERMINAL (MENGGUNAKAN TEXTINPUT BIAR WARNA NURUT)
            Rectangle {
                background: OdfizTheme.terminal-bg;
                border-radius: 12px;
                height: 200px;
                clip: true; // Biar teks gak luber keluar kotak

                VerticalBox {
                    padding: 12px;
                    spacing: 8px;
                    
                    // Header Bulatan Terminal
                    HorizontalBox {
                        alignment: start;
                        spacing: 6px;
                        Rectangle { width: 8px; height: 8px; border-radius: 4px; background: #ff5f56; }
                        Rectangle { width: 8px; height: 8px; border-radius: 4px; background: #ffbd2e; }
                        Rectangle { width: 8px; height: 8px; border-radius: 4px; background: #27c93f; }
                    }

                    // ScrollView buat isi log biar bisa di-scroll dan select
                    ScrollView {
                        viewport-height: log-content.preferred-height;
                        log-content := TextInput {
                            text: "➜ odfiz-core git:(main) ✗ \n" + root.status-text;
                            font-family: "monospace";
                            font-size: 13px;
                            color: OdfizTheme.terminal-text; // DI SINI JALAN!
                            read-only: true;
                            wrap: word-wrap;
                            single-line: false;
                        }
                    }
                }
            }

            Text {
                text: "ODFIZ NATIVE CORE V.4.9";
                font-size: 10px;
                color: #555;
                horizontal-alignment: center;
            }
        }
    }
}
