import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Secure";
    background: #1a1a2e;
    width: 400px;
    height: 600px;

    callback secure-now();
    callback refresh-pulse();
    in-out property <string> status-text: "Odfiz System Ready";
    in-out property <string> pulse-info: "RAM: --MB";

    VerticalBox {
        padding: 30px;
        spacing: 20px;
        alignment: start;

        // Ikon Launcher sebagai Logo Utama
        Image {
            source: @image-url("../app/src/main/res/mipmap-hdpi/ic_launcher.png");
            width: 100px;
            height: 100px;
            horizontal-alignment: center;
        }

        // Monitoring Box
        Rectangle {
            height: 80px;
            background: #0f3460;
            border-radius: 12px;
            Text {
                text: root.pulse-info;
                color: #00d2ff;
                font-size: 20px;
                font-weight: 700;
            }
        }

        // Status Area (Padding diperbaiki dengan membungkus Text dalam VerticalBox)
        Rectangle {
            background: #16213e;
            border-radius: 8px;
            VerticalBox {
                padding: 12px;
                Text {
                    text: root.status-text;
                    color: #eeeeee;
                    font-size: 14px;
                    wrap: word-wrap; // Fix: Gunakan word-wrap
                    horizontal-alignment: center;
                }
            }
        }

        Button {
            text: "SECURE DATA";
            primary: true;
            height: 55px;
            clicked => { root.secure-now() }
        }

        Button {
            text: "REFRESH SYSTEM";
            height: 50px;
            clicked => { root.refresh-pulse() }
        }
    }
}
