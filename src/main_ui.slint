import { Button, VerticalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Watermark Cam";
    background: #FFFFFF;
    
    in-out property <string> status-text: "Siap Ambil Foto";
    callback take-photo-watermark();

    ScrollView {
        VerticalBox {
            padding-top: 70px;
            spacing: 20px;

            Text {
                text: "Odfiz Camera System";
                font-size: 24px;
                font-weight: 700;
                horizontal-alignment: center;
            }

            Rectangle {
                background: #F5F5F5;
                border-radius: 12px;
                height: 100px;
                Text {
                    padding: 15px;
                    text: root.status-text;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                }
            }

            Button {
                text: "AMBIL FOTO + WATERMARK";
                primary: true;
                height: 55px;
                clicked => {
                    root.take-photo-watermark();
                }
            }
            
            Text {
                text: "Hasil akan disimpan otomatis ke folder Gallery";
                font-size: 12px;
                color: gray;
                horizontal-alignment: center;
            }
        }
    }
}
