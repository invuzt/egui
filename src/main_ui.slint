import { ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Premium";
    background: #FFFFFF;
    width: 400px;
    height: 800px;

    in-out property <string> current-view: "home";

    // --- STATIC HEADER (Mahal & Clean) ---
    Rectangle {
        y: 0; z: 100;
        width: 100%; height: 120px;
        background: #FFFFFF;
        
        Text {
            x: 25px; y: 65px;
            text: root.current-view == "home" ? "Overview" : "Service";
            font-size: 32px;
            font-weight: 800;
            color: #1C1C1E;
        }

        if (root.current-view != "home") : Rectangle {
            x: parent.width - 65px; y: 65px;
            width: 40px; height: 40px; border-radius: 20px;
            background: #F2F2F7;
            Text { text: "✕"; font-size: 16px; color: #1C1C1E; }
            TouchArea { clicked => { root.current-view = "home" } }
        }
    }

    // --- MAIN CONTENT ---
    ScrollView {
        y: 120px;
        height: parent.height - 120px;
        viewport-height: content-layout.preferred-height;

        content-layout := VerticalBox {
            padding: 25px;
            spacing: 30px;
            alignment: start;

            if (root.current-view == "home") : VerticalBox {
                spacing: 30px;
                padding: 0;

                // 1. MAIN CARD (High Contrast)
                Rectangle {
                    height: 200px;
                    background: #1C1C1E;
                    border-radius: 28px;
                    
                    // Dekorasi Lingkaran (Detail Mahal)
                    Rectangle {
                        x: parent.width - 100px; y: -30px;
                        width: 150px; height: 150px; border-radius: 75px;
                        background: #FFFFFF08;
                    }

                    VerticalBox {
                        padding: 30px;
                        alignment: space-around;
                        Text { text: "Current Assets"; color: #8E8E93; font-size: 14px; letter-spacing: 1px; }
                        Text { text: "$ 12,450.00"; color: white; font-size: 36px; font-weight: 800; }
                        
                        Rectangle {
                            width: 100px; height: 36px; border-radius: 18px;
                            background: #3A3A3C;
                            Text { text: "History"; color: white; font-size: 13px; font-weight: 600; }
                        }
                    }
                }

                // 2. FEATURE SECTION
                Text { text: "Digital Services"; color: #1C1C1E; font-size: 20px; font-weight: 800; }

                HorizontalBox {
                    padding: 0; spacing: 20px;
                    height: 140px;
                    
                    // Calculator Item
                    Rectangle {
                        background: #F9F9F9; border-radius: 24px;
                        border-width: 1px; border-color: #F2F2F7;
                        VerticalBox {
                            padding: 20px; alignment: space-around;
                            Text { text: "🧮"; font-size: 28px; }
                            Text { text: "Calculator"; color: #1C1C1E; font-size: 15px; font-weight: 700; }
                        }
                        TouchArea { clicked => { root.current-view = "calc" } }
                    }
                    
                    // Camera Item
                    Rectangle {
                        background: #F9F9F9; border-radius: 24px;
                        border-width: 1px; border-color: #F2F2F7;
                        VerticalBox {
                            padding: 20px; alignment: space-around;
                            Text { text: "📷"; font-size: 28px; }
                            Text { text: "Camera"; color: #1C1C1E; font-size: 15px; font-weight: 700; }
                        }
                        TouchArea { clicked => { root.current-view = "camera" } }
                    }
                }
            }

            if (root.current-view == "calc") : VerticalBox {
                padding: 0;
                Rectangle {
                    height: 100px; background: #F2F2F7; border-radius: 20px;
                    Text { text: "Calculator Module Active"; color: #8E8E93; font-weight: 600; }
                }
            }
        }
    }
}
