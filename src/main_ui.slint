import { Button, LineEdit, Slider, CheckBox, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Native Showcase";
    background: #FFFFFF;
    
    in-out property <string> input-text;
    in-out property <string> status-text: "Sistem Ready";
    
    callback process-data(string);
    callback open-camera();

    ScrollView {
        VerticalBox {
            padding-top: 70px;
            spacing: 15px;

            Text {
                text: "Odfiz Pro";
                font-size: 24px;
                font-weight: 700;
            }

            LineEdit {
                placeholder-text: "Ketik sesuatu...";
                text <=> root.input-text;
            }

            // Preview Status
            Rectangle {
                background: #F0F0F0;
                border-radius: 8px;
                height: 60px;
                Text {
                    padding: 10px;
                    text: root.status-text;
                    wrap: word-wrap;
                }
            }

            // Tombol Kamera
            Button {
                text: "BUKA KAMERA (INTENT)";
                clicked => {
                    root.open-camera();
                }
            }

            Button {
                text: "PROSES DATA";
                primary: true;
                height: 45px;
                clicked => {
                    root.process-data(root.input-text);
                }
            }
        }
    }
}
