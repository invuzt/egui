import { Button, VerticalBox, ScrollView, HorizontalBox, LineEdit, TextEdit } from "std-widgets.slint";

export global OdfizTheme {
    in property <color> bg-outer: #C0C4CC;
    in property <color> card-bg: #ffffff;
    in property <color> terminal-bg: #1a1b26;
    in property <color> accent-color: #ff4d6d;
    in property <color> text-primary: #1c1e21;
    in property <color> prompt-color: #7aa2f7;
    in property <color> path-color: #9ece6a;
    in property <length> safe-area-top: 60px;
}

component OdfizButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    background: touch.pressed ? OdfizTheme.accent-color.darker(10%) : OdfizTheme.accent-color;
    border-radius: 25px;
    height: 45px;
    width: 180px;
    animate background { duration: 150ms; }
    Text { text: root.text; color: white; font-weight: 800; }
    touch := TouchArea { clicked => { root.clicked() } }
}

export component AppWindow inherits Window {
    title: "Odfiz Native Processor";
    background: OdfizTheme.bg-outer;
    in-out property <string> status-text: "ready to process...";
    callback process-data(string);

    ScrollView {
        viewport-height: main-layout.preferred-height;
        
        main-layout := VerticalBox {
            padding: 20px;
            padding-top: OdfizTheme.safe-area-top;
            spacing: 15px;

            Rectangle {
                background: OdfizTheme.card-bg;
                border-radius: 20px;
                height: 160px;
                drop-shadow-blur: 15px;
                drop-shadow-color: #00000015;

                VerticalBox {
                    padding: 20px;
                    spacing: 15px;
                    input_field := LineEdit {
                        placeholder-text: "Input command or data...";
                        font-size: 16px;
                        height: 45px;
                    }
                    HorizontalBox {
                        alignment: center;
                        OdfizButton {
                            text: "RUN ENGINE";
                            clicked => { root.process-data(input_field.text) }
                        }
                    }
                }
            }

            Rectangle {
                background: OdfizTheme.terminal-bg;
                border-radius: 12px;
                height: 200px;
                border-width: 1px;
                border-color: #32344a;

                VerticalBox {
                    padding: 12px;
                    spacing: 5px;
                    
                    HorizontalBox {
                        alignment: start;
                        spacing: 6px;
                        Rectangle { width: 10px; height: 10px; border-radius: 5px; background: #ff5f56; }
                        Rectangle { width: 10px; height: 10px; border-radius: 5px; background: #ffbd2e; }
                        Rectangle { width: 10px; height: 10px; border-radius: 5px; background: #27c93f; }
                    }

                    TextEdit {
                        text: "➜  " + "odfiz-core " + "git:(main) ✗ " + root.status-text;
                        font-family: "monospace";
                        font-size: 13px;
                        // PERBAIKAN: Ganti 'color' menjadi 'text-color'
                        text-color: #a9b1d6;
                        read-only: true;
                        wrap: word-wrap;
                    }
                }
            }

            Text {
                text: "ODFIZ NATIVE CORE V.4.8";
                font-size: 10px;
                color: #555;
                horizontal-alignment: center;
            }
        }
    }
}
