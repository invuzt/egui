import { Button, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Apk Penghasil Uang VROH";
    background: #0d0d0d;
    preferred-width: 400px;
    preferred-height: 850px;

    in-out property <string> log-text: "[SYS] Initializing nodes...\n[INFO] Connecting to Odfiz Pool...";
    in-out property <string> balance: "0.00001245";
    in-out property <string> running-stats: "HASHRATE: 45.12 TH/s | DIFFICULTY: 82.5T | REWARD: 3.125 BTC";
    in-out property <string> admin-msg: ""; // Pesan dari Mas
    in-out property <float> progress: 0.4;
    in-out property <bool> is-mining: true;

    callback toggle-mining();

    VerticalBox {
        padding-top: 60px;
        padding-left: 20px;
        padding-right: 20px;
        spacing: 15px;

        Text {
            text: "Apk Penghasil Uang VROH";
            font-size: 24px;
            font-weight: 800;
            color: #ffffff;
            horizontal-alignment: center;
        }

        // --- ADMIN NOTIFICATION BOX ---
        if (admin-msg != "") : Rectangle {
            height: 50px;
            background: #ff4757;
            border-radius: 8px;
            HorizontalBox {
                alignment: center;
                Text { text: "⚠️ ADMIN: " + root.admin-msg; color: white; font-weight: 900; }
            }
        }

        // --- STATS CARD ---
        Rectangle {
            height: 140px;
            background: #16213e;
            border-radius: 12px;
            border-width: 1px;
            border-color: #39ff14;

            VerticalBox {
                alignment: center;
                padding: 15px;
                Text { text: "MINING PROFITABILITY"; color: #bbbbbb; font-size: 14px; }
                Text { text: root.balance + " BTC"; color: #39ff14; font-size: 36px; font-weight: 800; }
                Text { text: "LIVE UPDATE | TESTNET"; color: #555555; font-size: 11px; } // SUDAH FIX (;)
            }
        }

        // --- LOG VIEW ---
        Rectangle {
            background: #000;
            border-radius: 8px;
            height: 250px;
            ScrollView {
                padding: 10px;
                Text { text: root.log-text; color: #00ff00; font-family: "monospace"; font-size: 12px; wrap: word-wrap; }
            }
        }

        VerticalBox {
            spacing: 5px;
            Text { text: "BLOCK DISCOVERY PROGRESS"; color: #888; font-size: 11px; }
            Rectangle {
                height: 12px; background: #222; border-radius: 6px;
                Rectangle {
                    x: 0; width: parent.width * root.progress;
                    background: #39ff14; border-radius: 6px;
                }
            }
        }

        Button {
            text: root.is-mining ? "STOP MINER" : "START MINING ENGINE";
            primary: true;
            height: 55px;
            clicked => { root.toggle-mining() }
        }

        Text { text: "ODFIZ CORE v4.2 - @VROH"; color: #444; font-size: 11px; horizontal-alignment: center; }
    }
}
