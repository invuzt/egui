import { Button, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Odfiz Modern UI";
    background: #f4f7fa;
    default-font-family: "sans-serif";
    
    VerticalLayout {
        padding: 24px;
        padding-top: 65px; // Turun sedikit agar tidak tertutup Status Bar
        spacing: 22px;
        alignment: start;

        Text {
            text: "Odfiz Modern UI";
            font-size: 26px;
            font-weight: 800;
            color: #2d5af0;
            horizontal-alignment: center;
        }

        Text {
            text: "Running on Rust Slint Engine";
            font-size: 14px;
            color: #666;
            horizontal-alignment: center;
        }

        LineEdit {
            placeholder-text: "Cari data...";
            height: 48px;
        }

        Rectangle {
            background: white;
            border-radius: 16px;
            height: 110px;
            drop-shadow-blur: 15px;
            drop-shadow-color: #00000010;
            
            VerticalLayout {
                padding: 18px;
                spacing: 6px;
                Text {
                    text: "Dashboard Status";
                    font-size: 17px;
                    font-weight: 600;
                    color: #333;
                }
                Text {
                    text: "Sistem Ready - Performa Maksimal";
                    font-size: 13px;
                    color: #27ae60;
                }
            }
        }

        Button {
            text: "UPDATE SISTEM";
            primary: true;
            height: 52px;
        }
    }
}
